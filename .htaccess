<IfModule mod_rewrite.c>
    RewriteEngine On
    
    #
    # 1. Allow direct access to existing files and directories
    # For example, index.php, game.js, or image folders
    #
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    #
    # 2. Route all other API calls to api.php
    # e.g., /api/rest -> /api.php?action=rest
    # e.g., /api/combat/123 -> /api.php?action=combat/123
    #
    RewriteRule ^api/(.*)$ api.php?action=$1 [QSA,L]
</IfModule>

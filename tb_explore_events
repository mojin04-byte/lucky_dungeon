-- ==========================================
('ENC_B5_411', 'encounter', '적 조우', '푸른 영혼의 불꽃을 두른 언데드 마법사가 뼈로 된 지팡이를 치켜들고 저주를 시전한다.', 10, 1, 9999, 1),
('ENC_B5_412', 'encounter', '적 조우', '발소리 하나 내지 않는 유령 기사단이 방패를 앞세우고 서늘한 기운과 함께 압박해온다.', 10, 1, 9999, 1),
('ENC_B5_413', 'encounter', '적 조우', '허공을 떠도는 여인의 흉측한 원혼이 고막을 찢어버릴 듯한 비명을 지르며 덮쳐온다.', 10, 1, 9999, 1),
('ENC_B5_414', 'encounter', '적 조우', '양손에 낡은 곡도를 쥔 해골 검사가 관절이 없는 기괴한 속도로 회전하며 베어 들어온다.', 10, 1, 9999, 1),
('ENC_B5_415', 'encounter', '적 조우', '마른 붕대로 온몸이 감긴 미라 주술사가 썩은 독가스를 내뿜으며 흑마법을 외운다.', 10, 1, 9999, 1),
('ENC_B5_416', 'encounter', '적 조우', '바닥에 고여 있던 피가 끓어오르며 날카로운 선혈의 채찍을 든 핏빛 정령이 실체화된다.', 10, 1, 9999, 1),
('ENC_B5_417', 'encounter', '적 조우', '수백 개의 일그러진 얼굴을 한 영혼의 집합체가 끔찍한 환청으로 정신을 파괴하려 든다.', 10, 1, 9999, 1),
('ENC_B5_418', 'encounter', '적 조우', '속이 텅 빈 칠흑의 마법 갑옷이 바닥에 끌리는 무거운 대검을 질질 끌며 다가온다.', 10, 1, 9999, 1),
('ENC_B5_419', 'encounter', '적 조우', '검은 성서를 든 타락한 이단 사제가 파멸의 기도를 올리며 불길한 암흑 마법을 내린다.', 10, 1, 9999, 1),
('ENC_B5_420', 'encounter', '적 조우', '통제를 잃은 순수 마력 덩어리가 번개를 사방으로 흩뿌리며 맹렬하게 회전하며 돌진한다.', 10, 1, 9999, 1),

-- ==========================================
-- ⚔️ 적 조우 (기습 및 함정 연계)
-- ==========================================
('ENC_B5_421', 'encounter', '적 조우', '보물 상자를 여는 순간 등 뒤에서 그물이 떨어지고, 도적 떼가 환호성을 지르며 기습한다.', 10, 1, 9999, 1),
('ENC_B5_422', 'encounter', '적 조우', '짙은 그림자 속에 완벽하게 은신하고 있던 다크 엘프 암살자가 독이 발린 단검을 꽂아 넣는다.', 10, 1, 9999, 1),
('ENC_B5_423', 'encounter', '적 조우', '화려한 황금 문을 열려는 순간, 문 자체가 거대한 입이 되어 날카로운 이빨로 집어삼키려 한다.', 10, 1, 9999, 1),
('ENC_B5_424', 'encounter', '적 조우', '버려진 제단 밑에 숨어있던 광신도 무리가 독이 발린 비수를 쥐고 미친 듯이 튀어나온다.', 10, 1, 9999, 1),
('ENC_B5_425', 'encounter', '적 조우', '통로를 걷는 도중 천장의 굳어있던 가고일 조각상이 돌연 살아 움직이며 어깨를 낚아챈다.', 10, 1, 9999, 1),
('ENC_B5_426', 'encounter', '적 조우', '평범한 물웅덩이인 줄 알고 밟는 순간, 위장하고 있던 강산성 슬라임이 다리를 집어삼킨다.', 10, 1, 9999, 1),
('ENC_B5_427', 'encounter', '적 조우', '등에 불안정한 마법 폭약이 묶인 돌연변이 쥐 떼가 미친 듯한 속도로 발밑을 향해 쇄도한다.', 10, 1, 9999, 1),
('ENC_B5_428', 'encounter', '적 조우', '살려달라 애원하던 부상자가 가까이 다가가자 표정을 싹 바꾸며 옷 속에 숨긴 석궁을 쏜다.', 10, 1, 9999, 1),
('ENC_B5_429', 'encounter', '적 조우', '안도하며 열어젖힌 출구가 환상 마법이었고, 얇은 벽 너머의 몬스터 둥지로 곧장 추락한다.', 10, 1, 9999, 1),
('ENC_B5_430', 'encounter', '적 조우', '바닥의 함정을 신경 쓰느라 미처 보지 못한 천장의 거미 괴물이 치명적인 독거미줄을 뿜는다.', 10, 1, 9999, 1),


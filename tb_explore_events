INSERT IGNORE INTO `tb_explore_events` (`event_id`, `event_code`, `event_type`, `event_title`, `ai_seed`, `weight`, `min_floor`, `max_floor`, `is_enabled`) VALUES
-- ==========================================
-- ⚔️ 적 조우 (Encounter) - 30개 다양화
-- ==========================================
(1, 'ENCOUNTER_001', 'encounter', '적 조우', '어둠 속 발소리가 겹쳐 울리며 접근한다. 낡은 무기가 바닥을 긁는 소리가 선명하다.', 10, 1, 9999, 1),
(2, 'ENCOUNTER_002', 'encounter', '적 조우', '금속성 숨소리가 벽을 타고 스며든다. 썩은 피 냄새가 코끝을 찌른다.', 10, 1, 9999, 1),
(3, 'ENCOUNTER_003', 'encounter', '적 조우', '핏빛 기운이 천천히 시야를 잠식한다. 누군가 미쳐가는 듯한 웃음소리가 들린다.', 10, 1, 9999, 1),
(4, 'ENCOUNTER_004', 'encounter', '적 조우', '잔해 사이에서 적의 눈빛이 번쩍인다. 기습을 준비하는 짐승의 헐떡임이 느껴진다.', 10, 1, 9999, 1),
(5, 'ENCOUNTER_005', 'encounter', '적 조우', '정적이 깨지며 포효가 복도를 울린다. 바닥의 돌들이 진동하며 다가오는 무게감을 증명한다.', 10, 1, 9999, 1),
(6, 'ENCOUNTER_006', 'encounter', '적 조우', '발밑의 그림자가 갑자기 길게 늘어진다. 보이지 않는 적이 사각지대에서 덮쳐온다.', 10, 1, 9999, 1),
(7, 'ENCOUNTER_007', 'encounter', '적 조우', '낮은 울음과 함께 괴이한 형체가 드러난다. 이성을 잃은 괴물의 침이 뚝뚝 떨어진다.', 10, 1, 9999, 1),
(8, 'ENCOUNTER_008', 'encounter', '적 조우', '칼날 같은 살기가 통로를 가르며 짙게 번진다. 훈련받은 암살자의 차가운 기운이다.', 10, 1, 9999, 1),
(9, 'ENCOUNTER_009', 'encounter', '적 조우', '벽에 걸린 횃불이 일제히 꺼지며, 사방에서 날카로운 발톱 소리가 울린다.', 10, 1, 9999, 1),
(10, 'ENCOUNTER_010', 'encounter', '적 조우', '고기 썩는 악취가 진동하더니, 천장에서 끈적한 체액이 떨어지며 적이 낙하한다.', 10, 1, 9999, 1),
(11, 'ENCOUNTER_011', 'encounter', '적 조우', '갑옷이 부딪히는 둔탁한 소리. 언데드 군단이 진형을 갖추고 압박해 온다.', 10, 1, 9999, 1),
(12, 'ENCOUNTER_012', 'encounter', '적 조우', '환영처럼 일렁이는 공간 너머로 마법의 기운을 품은 적이 영창을 시작한다.', 10, 1, 9999, 1),
(13, 'ENCOUNTER_013', 'encounter', '적 조우', '바닥에 깔린 뼈무더기가 달그락거리며 일어나더니, 살아있는 자의 온기를 향해 고개를 돌린다.', 10, 1, 9999, 1),
(14, 'ENCOUNTER_014', 'encounter', '적 조우', '기분 나쁜 진동음과 함께 벽의 일부가 허물어지며 거대한 짐승이 튀어나온다.', 10, 1, 9999, 1),
(15, 'ENCOUNTER_015', 'encounter', '적 조우', '죽어가는 모험가의 비명소리가 미끼였다. 함정을 판 적들이 서서히 포위망을 좁혀온다.', 10, 1, 9999, 1),
(16, 'ENCOUNTER_016', 'encounter', '적 조우', '어스름한 달빛 아래, 창백한 피부의 괴수가 당신의 피를 노리며 날카로운 이를 드러낸다.', 10, 1, 9999, 1),
(17, 'ENCOUNTER_017', 'encounter', '적 조우', '갑작스런 돌풍이 불며 시야가 가려진 틈을 타 누군가 당신의 목을 노리고 검을 휘두른다.', 10, 1, 9999, 1),
(18, 'ENCOUNTER_018', 'encounter', '적 조우', '웅덩이에서 기포가 올라오더니, 물보라와 함께 끔찍한 수중 괴물이 솟구친다.', 10, 1, 9999, 1),
(19, 'ENCOUNTER_019', 'encounter', '적 조우', '저주받은 신상 앞에서 의식을 치르던 광신도들이 당신을 제물로 삼으려 달려든다.', 10, 1, 9999, 1),
(20, 'ENCOUNTER_020', 'encounter', '적 조우', '시계태엽이 돌아가는 째깍 소리와 함께, 고대의 살인 기계가 눈을 번뜩이며 가동된다.', 10, 1, 9999, 1),
(21, 'ENCOUNTER_021', 'encounter', '적 조우', '벽면에 붙어있던 담쟁이덩굴이 살아서 움직이듯 꿈틀거리며 당신의 발목을 옥죈다.', 10, 1, 9999, 1),
(22, 'ENCOUNTER_022', 'encounter', '적 조우', '바닥의 균열에서 뜨거운 열기가 뿜어져 나오며, 화염을 두른 악마가 나타난다.', 10, 1, 9999, 1),
(23, 'ENCOUNTER_023', 'encounter', '적 조우', '거미줄로 뒤덮인 방 중앙에 도달하자, 사방의 알들이 부화하며 끔찍한 소리가 들린다.', 10, 1, 9999, 1),
(24, 'ENCOUNTER_024', 'encounter', '적 조우', '알 수 없는 독기가 퍼진 방. 기침을 하는 사이 돌연변이 괴수가 등 뒤에서 나타난다.', 10, 1, 9999, 1),
(25, 'ENCOUNTER_025', 'encounter', '적 조우', '거대한 문을 여는 순간, 안쪽에서 대기하고 있던 적의 창날이 맹렬하게 찔러 들어온다.', 10, 1, 9999, 1),
(26, 'ENCOUNTER_026', 'encounter', '적 조우', '공허한 동굴에서 메아리가 끊기더니, 그림자 속에서 형체를 알 수 없는 악령이 스며 나온다.', 10, 1, 9999, 1),
(27, 'ENCOUNTER_027', 'encounter', '적 조우', '마법의 결계가 발동하며 퇴로가 막힌다. 결계 중앙에서 골렘이 육중한 주먹을 들어 올린다.', 10, 1, 9999, 1),
(28, 'ENCOUNTER_028', 'encounter', '적 조우', '피 묻은 동전들을 줍는 순간, 탐욕에 눈이 먼 약탈자들이 어둠 속에서 칼을 빼든다.', 10, 1, 9999, 1),
(29, 'ENCOUNTER_029', 'encounter', '적 조우', '유리처럼 부서지는 환상. 그 뒤에는 굶주린 마수가 입을 벌리고 당신을 기다리고 있었다.', 10, 1, 9999, 1),
(30, 'ENCOUNTER_030', 'encounter', '적 조우', '침묵의 복도. 오직 당신의 심장 소리만 들릴 때, 눈앞에 피에 굶주린 처형자가 서 있다.', 10, 1, 9999, 1),

-- ==========================================
-- 💰 골드/보물 획득 (Gold / Chest) - 30개 다양화
-- ==========================================
(31, 'GOLD_001', 'gold', '동전 주머니', '해골이 움켜쥐고 있던 낡은 가죽 주머니에서 짤랑거리는 소리가 난다.', 10, 1, 9999, 1),
(32, 'GOLD_002', 'gold', '숨겨진 보석', '무너진 벽돌 틈새로 기묘한 빛이 새어 나온다. 파내어 보니 제법 값나가는 보석이다.', 10, 1, 9999, 1),
(33, 'CHEST_001', 'chest', '낡은 목재 상자', '곰팡이가 핀 나무 상자의 녹슨 자물쇠를 부수자, 잊혀진 금화가 모습을 드러낸다.', 10, 1, 9999, 1),
(34, 'CHEST_002', 'chest', '화려한 은장식 상자', '먼지 속에 파묻혀 있던 은장식 상자를 열자 찬란한 빛이 눈을 멀게 한다.', 10, 1, 9999, 1),
(35, 'GOLD_003', 'gold', '버려진 전리품', '이전에 다녀간 탐험가의 배낭이 찢겨 있다. 다행히 내용물은 무사하다.', 10, 1, 9999, 1),
(36, 'CHEST_003', 'chest', '고대의 유물함', '상자에 새겨진 고대 룬을 해석하여 열자, 막대한 부가 쏟아져 나온다.', 10, 1, 9999, 1),
(37, 'GOLD_004', 'gold', '마석 조각', '바닥에 떨어져 있는 신비한 광석 조각을 주웠다. 꽤 비싸게 팔릴 것 같다.', 10, 1, 9999, 1),
(38, 'GOLD_005', 'gold', '은닉처 발견', '바닥의 이질적인 타일을 들어 올리자, 누군가 숨겨둔 비상금이 나타난다.', 10, 1, 9999, 1),
(39, 'CHEST_004', 'chest', '철제 금고', '기름을 쳐서 간신히 철제 금고의 다이얼을 돌렸다. 안에는 금괴가 쌓여 있다.', 10, 1, 9999, 1),
(40, 'GOLD_006', 'gold', '귀족의 반지', '시궁창 쥐가 물고 가던 반짝이는 반지를 쳐서 빼앗았다. 세공이 훌륭하다.', 10, 1, 9999, 1),
(41, 'CHEST_005', 'chest', '저주받은 보물', '상자를 여는 순간 스산한 한기가 돌지만, 안의 보석들은 진짜다.', 10, 1, 9999, 1),
(42, 'GOLD_007', 'gold', '제단의 공물', '신에게 바쳐진 듯한 공물 접시에서 몇 닢의 금화를 슬쩍 챙긴다.', 10, 1, 9999, 1),
(43, 'GOLD_008', 'gold', '빛나는 동전', '진흙투성이 웅덩이 속에서 유달리 반짝이는 황금 동전을 건져 올린다.', 10, 1, 9999, 1),
(44, 'CHEST_006', 'chest', '해적의 상자', '미궁 깊은 곳에서 어울리지 않는 바다 냄새 나는 나무 상자를 발견해 열었다.', 10, 1, 9999, 1),
(45, 'GOLD_009', 'gold', '순금 조각상', '벽에 장식된 흉측한 가고일 조각상의 눈알이 순금인 것을 눈치챘다.', 10, 1, 9999, 1),
(46, 'CHEST_007', 'chest', '얼어붙은 상자', '얼음 기둥 속에 갇힌 상자를 조심스레 녹여내어 열어본다.', 10, 1, 9999, 1),
(47, 'GOLD_010', 'gold', '떨어진 펜던트', '어둠 속에서 발에 채인 무언가를 집어보니 가치가 높은 귀족의 펜던트였다.', 10, 1, 9999, 1),
(48, 'GOLD_011', 'gold', '광맥 발견', '동굴 벽면을 타고 흐르는 얇은 금맥을 곡괭이로 파내어 주머니에 담았다.', 10, 1, 9999, 1),
(49, 'CHEST_008', 'chest', '마법 잠금 상자', '마력을 주입하자 '딸깍' 소리와 함께 공간이 열리며 귀한 마석들이 나타난다.', 10, 1, 9999, 1),
(50, 'GOLD_012', 'gold', '왕가의 식기', '버려진 연회장에서 찌그러진 황금 식기를 발견해 주워 담는다.', 10, 1, 9999, 1),
(51, 'CHEST_009', 'chest', '불타는 상자', '용암 주변에 아슬아슬하게 놓인 상자를 갈고리로 끌어와 조심스레 연다.', 10, 1, 9999, 1),
(52, 'GOLD_013', 'gold', '모험가의 지갑', '거미줄에 칭칭 감긴 백골이 품고 있던 두툼한 가죽 지갑을 챙긴다.', 10, 1, 9999, 1),
(53, 'GOLD_014', 'gold', '신성한 주화', '성기사의 묘비 위에 놓인 눈부신 주화를 조심스레 가져온다.', 10, 1, 9999, 1),
(54, 'CHEST_010', 'chest', '기계 장치 상자', '복잡한 톱니바퀴 퍼즐을 풀어내자 기계 상자가 열리며 전리품을 내어준다.', 10, 1, 9999, 1),
(55, 'GOLD_015', 'gold', '금니', '쓰러진 오크 대장의 입에서 굵직한 금니를 뽑아낸다.', 10, 1, 9999, 1),
(56, 'CHEST_011', 'chest', '미궁의 눈물', '투명한 크리스털 상자 안에 푸른빛을 뿜어내는 마력석들이 가득하다.', 10, 1, 9999, 1),
(57, 'GOLD_016', 'gold', '상단의 유실물', '파괴된 상단의 수레에서 굴러떨어진 진귀한 향신료와 금화를 줍는다.', 10, 1, 9999, 1),
(58, 'GOLD_017', 'gold', '빛나는 비늘', '용의 둥지 근처에서 떨어진 금빛 비늘 한 장을 득템한다.', 10, 1, 9999, 1),
(59, 'CHEST_012', 'chest', '피 묻은 상자', '치열한 전투의 흔적이 남은 방 중앙, 승자의 전리품이 담긴 상자가 열려 있다.', 10, 1, 9999, 1),
(60, 'GOLD_018', 'gold', '우상 조각', '제단에 모셔져 있던 금으로 된 기괴한 우상의 팔을 부러뜨려 가져간다.', 10, 1, 9999, 1),

-- ==========================================
-- 🩸 함정 (Trap) - 20개 다양화
-- ==========================================
(61, 'TRAP_001', 'trap', '낙석 함정', '천장에서 우르릉거리는 소리가 나더니, 집채만 한 바위가 등 뒤로 떨어진다.', 5, 1, 9999, 1),
(62, 'TRAP_002', 'trap', '독 화살', '압력판을 밟자마자 벽의 미세한 구멍에서 맹독을 바른 화살이 빗발친다.', 5, 1, 9999, 1),
(63, 'TRAP_003', 'trap', '불꽃 함정', '문고리를 돌리는 순간 거대한 화염이 뿜어져 나와 얼굴을 덮친다.', 5, 1, 9999, 1),
(64, 'TRAP_004', 'trap', '부식성 가스', '환풍구에서 녹색 가스가 뿜어져 나와 호흡기를 태울 듯한 고통을 준다.', 5, 1, 9999, 1),
(65, 'TRAP_005', 'trap', '환영의 함정', '멀쩡해 보이는 다리를 밟았으나 허공이었고, 깊은 구덩이로 굴러떨어진다.', 5, 1, 9999, 1),
(66, 'TRAP_006', 'trap', '회전하는 톱니', '복도 양쪽에서 거대한 톱니바퀴가 튀어나와 뼈를 깎을 듯이 긁고 지나간다.', 5, 1, 9999, 1),
(67, 'TRAP_007', 'trap', '저주받은 룬', '바닥의 문양을 잘못 밟아 저주가 발동, 온몸의 피가 역류하는 고통을 겪는다.', 5, 1, 9999, 1),
(68, 'TRAP_008', 'trap', '산성 늪', '어두운 웅덩이를 잘못 딛어 산성 용액에 다리가 잠기며 살이 타들어 간다.', 5, 1, 9999, 1),
(69, 'TRAP_009', 'trap', '거미줄 덫', '보이지 않는 끈끈한 줄에 걸려 발버둥 치는 사이 날카로운 실이 살을 파고든다.', 5, 1, 9999, 1),
(70, 'TRAP_010', 'trap', '얼음 송곳', '천장의 거대한 고드름이 갑자기 떨어져 어깨를 깊숙이 찌른다.', 5, 1, 9999, 1),
(71, 'TRAP_011', 'trap', '기계 집게', '벽에서 튀어나온 쇠집게가 갈비뼈를 움켜쥐고 내동댕이친다.', 5, 1, 9999, 1),
(72, 'TRAP_012', 'trap', '환각 버섯', '발밑의 버섯이 터지며 환각 포자가 퍼져 스스로 자해하게 만든다.', 5, 1, 9999, 1),
(73, 'TRAP_013', 'trap', '거울의 방', '거울 속 자신의 환영이 튀어나와 짧지만 치명적인 일격을 날리고 사라진다.', 5, 1, 9999, 1),
(74, 'TRAP_014', 'trap', '모래지옥', '바닥이 모래처럼 변하며 빨려 들어가다 간신히 밧줄을 잡고 빠져나왔다.', 5, 1, 9999, 1),
(75, 'TRAP_015', 'trap', '마력 역류', '보물인 줄 알고 만진 구슬이 터지며 마력이 역류하여 내상을 입힌다.', 5, 1, 9999, 1),
(76, 'TRAP_016', 'trap', '유령의 비명', '방에 갇힌 억울한 영혼들의 비명소리가 귓막을 찢을 듯이 울려 퍼진다.', 5, 1, 9999, 1),
(77, 'TRAP_017', 'trap', '독 가시밭', '어두운 바닥에 깔린 독 가시들을 미처 피하지 못하고 뒹굴어 버렸다.', 5, 1, 9999, 1),
(78, 'TRAP_018', 'trap', '가짜 문', '문을 열자마자 육중한 철구가 그네처럼 날아와 복부를 강타한다.', 5, 1, 9999, 1),
(79, 'TRAP_019', 'trap', '공간 압축', '방의 양쪽 벽이 갑자기 좁아지며 갈비뼈가 으스러질 듯한 압박감을 준다.', 5, 1, 9999, 1),
(80, 'TRAP_020', 'trap', '피의 제단', '제단을 지나칠 때 보이지 않는 칼날이 손목을 베어 피를 바치게 만든다.', 5, 1, 9999, 1),

-- ==========================================
-- 💚 회복/마나 샘 (Heal / Mana Spring) - 15개 다양화
-- ==========================================
(81, 'HEAL_001', 'heal', '성스러운 샘물', '황금빛으로 빛나는 맑은 샘물을 마시자, 깊은 상처가 씻은 듯이 아문다.', 5, 1, 9999, 1),
(82, 'HEAL_002', 'heal', '요정의 이슬', '바위 틈에서 자라난 신비한 꽃에 맺힌 이슬을 핥자 생기가 돈다.', 5, 1, 9999, 1),
(83, 'MANA_001', 'mana_spring', '마력의 결정체', '부서진 제단 위에서 온전하게 남아있는 마력석을 흡수하여 기력을 되찾는다.', 5, 1, 9999, 1),
(84, 'HEAL_003', 'heal', '천사의 숨결', '어디선가 불어온 따뜻한 바람이 몸을 감싸며 피로를 모두 날려버린다.', 5, 1, 9999, 1),
(85, 'MANA_002', 'mana_spring', '고요한 명상소', '수정으로 둘러싸인 조용한 방에서 잠시 눈을 감자 흐트러진 마나가 정돈된다.', 5, 1, 9999, 1),
(86, 'HEAL_004', 'heal', '치유의 약초', '은은한 향을 내는 이름 모를 약초를 씹어 삼키자 근육의 통증이 사라진다.', 5, 1, 9999, 1),
(87, 'MANA_003', 'mana_spring', '별빛의 파편', '천장의 틈새로 새어 들어온 한 줄기 신비한 별빛이 마력을 채워준다.', 5, 1, 9999, 1),
(88, 'HEAL_005', 'heal', '생명의 나무', '미궁 한가운데서 자라난 거대한 고목의 수액을 마시고 활력을 되찾는다.', 5, 1, 9999, 1),
(89, 'MANA_004', 'mana_spring', '마법진 잔해', '바닥에 희미하게 남은 회복의 마법진 위에 서자 기운이 차오른다.', 5, 1, 9999, 1),
(90, 'HEAL_006', 'heal', '따뜻한 온천', '자연적으로 형성된 미니 온천에 몸을 담그고 독기와 상처를 씻어낸다.', 5, 1, 9999, 1),
(91, 'MANA_005', 'mana_spring', '시간의 모래시계', '부서진 마법의 모래시계에서 흘러나온 시간의 가루가 육체의 시간을 조금 되돌린다.', 5, 1, 9999, 1),
(92, 'HEAL_007', 'heal', '신의 눈물', '여신상의 눈동자에서 떨어진 신성한 액체가 모든 저주를 정화한다.', 5, 1, 9999, 1),
(93, 'MANA_006', 'mana_spring', '정령의 숲', '지하에서 자라난 신비한 형광 버섯 군락지가 뿜어내는 마력을 들이마신다.', 5, 1, 9999, 1),
(94, 'HEAL_008', 'heal', '태고의 비약', '죽은 연금술사의 가방에서 온전한 상태의 붉은 물약을 발견해 들이킨다.', 5, 1, 9999, 1),
(95, 'MANA_007', 'mana_spring', '마력 응축지', '허공에 부유하는 푸른 마력 덩어리에 손을 대자 찌릿한 쾌감과 함께 기운이 솟는다.', 5, 1, 9999, 1),

-- ==========================================
-- 📖 지식/경험치 (Exp / Flavor) - 10개 다양화
-- ==========================================
(96, 'EXP_001', 'exp', '오래된 전술서', '피 묻은 병사의 수첩을 읽고, 마수들의 약점을 찌르는 새로운 기술을 깨닫는다.', 3, 1, 9999, 1),
(97, 'EXP_002', 'exp', '마법사의 일지', '반쯤 타버린 두꺼운 양피지에서 마력 운용의 극의를 터득했다.', 3, 1, 9999, 1),
(98, 'EXP_003', 'exp', '벽화의 비밀', '벽에 새겨진 고대 전투의 기하학적 묘사를 보며 무기 다루는 법이 한층 날카로워졌다.', 3, 1, 9999, 1),
(99, 'EXP_004', 'exp', '선구자의 유언', '죽어가는 탐험가가 피로 쓴 미궁의 지도를 보고 생존에 대한 통찰을 얻었다.', 3, 1, 9999, 1),
(100, 'EXP_005', 'exp', '명상의 시간', '아무도 없는 고요한 방에서 자신의 전투를 복기하며 마음가짐을 단단히 했다.', 3, 1, 9999, 1),
(101, 'FLAVOR_001', 'flavor', '기괴한 콧노래', '아무도 없는 복도에서 어린아이의 콧노래 소리가 등 뒤를 따라온다.', 3, 1, 9999, 1),
(102, 'FLAVOR_002', 'flavor', '스쳐간 그림자', '시야 끝에서 무언가 휙 지나가는 것이 보였지만, 돌아보면 벽뿐이다.', 3, 1, 9999, 1),
(103, 'FLAVOR_003', 'flavor', '온기 없는 바람', '지하 깊은 곳임에도 불구하고, 뼛속까지 시린 한랭한 돌풍이 뺨을 스친다.', 3, 1, 9999, 1),
(104, 'FLAVOR_004', 'flavor', '누군가의 시선', '어둠 속에 박힌 붉은 눈동자 수십 개가 나를 쳐다보는 듯한 끔찍한 기분이 든다.', 3, 1, 9999, 1),
(105, 'FLAVOR_005', 'flavor', '미쳐버린 메아리', '내가 걷는 발소리와 정확히 1초의 간격을 두고 누군가 똑같이 걷는 소리가 난다.', 3, 1, 9999, 1);

INSERT INTO `tb_explore_events` (`event_code`, `event_type`, `event_title`, `ai_seed`, `weight`, `min_floor`, `max_floor`, `is_enabled`) VALUES
-- ==========================================
-- ⚔️ 적 조우 (야수 및 괴물형)
-- ==========================================
('ENC_B1_001', 'encounter', '적 조우', '천장에 매달려 있던 거대한 고치가 찢어지며 흉측한 마수가 쏟아져 내린다.', 10, 1, 9999, 1),
('ENC_B1_002', 'encounter', '적 조우', '바닥에 흩어진 시체들이 갑자기 융합하더니 끔찍한 살덩어리 괴물로 일어난다.', 10, 1, 9999, 1),
('ENC_B1_003', 'encounter', '적 조우', '짙은 안개 속에서 두 개의 붉은 안광이 번뜩이더니 맹렬한 속도로 돌진해온다.', 10, 1, 9999, 1),
('ENC_B1_004', 'encounter', '적 조우', '벽면의 석상인 줄 알았던 가고일이 굳은 잿가루를 털어내며 날개를 펼친다.', 10, 1, 9999, 1),
('ENC_B1_005', 'encounter', '적 조우', '물웅덩이를 밟는 순간, 액체가 소용돌이치며 물의 정령이 공격 형태를 취한다.', 10, 1, 9999, 1),
('ENC_B1_006', 'encounter', '적 조우', '시야를 가리는 거미줄을 베어내자 굶주린 거대 거미 떼가 사방에서 몰려온다.', 10, 1, 9999, 1),
('ENC_B1_007', 'encounter', '적 조우', '죽은 줄 알았던 거대 지네의 신경절이 다시 이어지며 독니를 치켜든다.', 10, 1, 9999, 1),
('ENC_B1_008', 'encounter', '적 조우', '바닥을 기어 다니던 그림자들이 하나로 뭉쳐 날카로운 낫을 든 악령이 된다.', 10, 1, 9999, 1),
('ENC_B1_009', 'encounter', '적 조우', '갑자기 땅이 솟아오르며, 단단한 암석으로 덮인 골렘이 흙먼지를 일으킨다.', 10, 1, 9999, 1),
('ENC_B1_010', 'encounter', '적 조우', '천장에서 떨어진 핏방울이 바닥에 닿자마자 끓어오르며 슬라임으로 변이한다.', 10, 1, 9999, 1),

-- ==========================================
-- ⚔️ 적 조우 (언데드 및 마법형)
-- ==========================================
('ENC_B1_011', 'encounter', '적 조우', '관 뚜껑이 박살 나며, 수백 년 전 묻힌 기사가 녹슨 대검을 끌며 걸어 나온다.', 10, 1, 9999, 1),
('ENC_B1_012', 'encounter', '적 조우', '허공에 기하학적인 마법진이 그려지며 차원의 틈새에서 악마가 소환된다.', 10, 1, 9999, 1),
('ENC_B1_013', 'encounter', '적 조우', '미쳐버린 수도사가 금단의 주문을 외우며 저주받은 사역마들을 부려댄다.', 10, 1, 9999, 1),
('ENC_B1_014', 'encounter', '적 조우', '목이 잘린 시체가 자신의 머리를 한 손에 들고 অন্য 한 손으로는 도끼를 휘두른다.', 10, 1, 9999, 1),
('ENC_B1_015', 'encounter', '적 조우', '바닥의 해골들이 스스로 조립되더니 뼈로 된 거대한 뱀의 형상을 띤다.', 10, 1, 9999, 1),
('ENC_B1_016', 'encounter', '적 조우', '어둠 속에서 떠도는 유령들이 사령관의 생기를 탐하며 얼음처럼 차갑게 덮쳐온다.', 10, 1, 9999, 1),
('ENC_B1_017', 'encounter', '적 조우', '핏빛 마력을 두른 마법사가 기분 나쁜 웃음을 흘리며 화염구를 준비한다.', 10, 1, 9999, 1),
('ENC_B1_018', 'encounter', '적 조우', '무너진 제단 위에서 죽음의 기운이 모이더니 거대한 리치의 환영이 실체화된다.', 10, 1, 9999, 1),
('ENC_B1_019', 'encounter', '적 조우', '버려진 인형들이 기괴한 관절 소리를 내며 독이 묻은 바늘을 들고 다가온다.', 10, 1, 9999, 1),
('ENC_B1_020', 'encounter', '적 조우', '책장에 꽂혀 있던 낡은 마도서들이 스스로 펄럭이며 마력의 칼날을 뿜어낸다.', 10, 1, 9999, 1),

-- ==========================================
-- ⚔️ 적 조우 (기습 및 인간형)
-- ==========================================
('ENC_B1_021', 'encounter', '적 조우', '함정을 해제하려는 찰나, 등 뒤로 소리 없이 다가온 암살자의 단검이 빛난다.', 10, 1, 9999, 1),
('ENC_B1_022', 'encounter', '적 조우', '살려달라는 비명소리를 듣고 다가간 곳엔, 인육을 탐하는 도적 떼가 숨어있었다.', 10, 1, 9999, 1),
('ENC_B1_023', 'encounter', '적 조우', '바닥으로 위장하고 있던 거대한 뚜껑이 열리며 흉악한 식인 식물이 입을 벌린다.', 10, 1, 9999, 1),
('ENC_B1_024', 'encounter', '적 조우', '보물 상자인 줄 알고 손을 뻗자, 상자가 끔찍한 이빨을 드러내며 손목을 물어뜯는다.', 10, 1, 9999, 1),
('ENC_B1_025', 'encounter', '적 조우', '천장에 붙어있던 위장색의 닌자가 표창을 쏟아내며 바닥으로 강하한다.', 10, 1, 9999, 1),
('ENC_B1_026', 'encounter', '적 조우', '미궁에 미쳐버린 전직 모험가가 자신의 동료들을 뜯어먹다 말고 고개를 돌린다.', 10, 1, 9999, 1),
('ENC_B1_027', 'encounter', '적 조우', '바람 소리인 줄 알았던 것은 사실 독침을 장전한 원주민들의 숨소리였다.', 10, 1, 9999, 1),
('ENC_B1_028', 'encounter', '적 조우', '벽 뒤의 비밀 공간이 깨지며, 오랜 시간 굶주린 이교도 전사들이 쏟아져 나온다.', 10, 1, 9999, 1),
('ENC_B1_029', 'encounter', '적 조우', '가짜 치유의 샘물 안에서 기괴한 변종 인어들이 튀어나와 발목을 잡아끈다.', 10, 1, 9999, 1),
('ENC_B1_030', 'encounter', '적 조우', '바닥에 깔린 융단이 솟아오르며, 그 안에 숨어있던 철갑 기계병이 기동한다.', 10, 1, 9999, 1),

-- ==========================================
-- 💰 골드 획득 (자연스러운 파밍 묘사)
-- ==========================================
('GLD_B1_031', 'gold', '숨겨진 동전', '금이 간 벽돌 틈새를 단검으로 파내자 흙먼지와 함께 오래된 금화가 쏟아진다.', 4, 1, 9999, 1),
('GLD_B1_032', 'gold', '죽은 자의 유산', '녹아내린 갑옷 안에 남아있던 은화 주머니를 조심스럽게 꺼내 품에 넣는다.', 4, 1, 9999, 1),
('GLD_B1_033', 'gold', '빛나는 잔해', '방금 베어 넘긴 몬스터의 위장 속에서 소화되지 않은 보석 원석을 발견했다.', 4, 1, 9999, 1),
('GLD_B1_034', 'gold', '바닥의 틈새', '밟고 지나가던 석판 하나가 덜컥 흔들린다. 들어 올려보니 그 아래 은닉 자금이 있다.', 4, 1, 9999, 1),
('GLD_B1_035', 'gold', '버려진 수레', '누군가 버리고 도망간 나무 수레 구석에 미처 챙기지 못한 금괴 하나가 빛난다.', 4, 1, 9999, 1),
('GLD_B1_036', 'gold', '우물의 바닥', '말라붙은 옛 우물 안쪽을 로프를 타고 내려가자 반짝이는 룬 조각들이 널려있다.', 4, 1, 9999, 1),
('GLD_B1_037', 'gold', '해골의 손', '해골이 끝까지 쥐고 놓지 않은 가죽 파우치를 힘주어 빼앗았다. 안에는 골드가 가득하다.', 4, 1, 9999, 1),
('GLD_B1_038', 'gold', '제단의 뒤편', '기분 나쁜 제단을 뒤져보자 검은 천으로 감싸놓은 헌금 상자를 찾아낼 수 있었다.', 4, 1, 9999, 1),
('GLD_B1_039', 'gold', '부서진 무기', '산산조각 난 명검의 자루 부분에 박혀있던 값비싼 루비를 단검으로 도려냈다.', 4, 1, 9999, 1),
('GLD_B1_040', 'gold', '기괴한 둥지', '거미줄로 뒤덮인 둥지를 횃불로 태우자, 희생자들의 품에 있던 동전들이 바닥에 떨어진다.', 4, 1, 9999, 1),

-- ==========================================
-- 📦 상자 발견 (Chest)
-- ==========================================
('CST_B1_041', 'chest', '이끼 낀 상자', '초록색 이끼로 뒤덮인 작은 나무 상자를 열쇠 구멍째로 박살 내고 전리품을 챙긴다.', 4, 1, 9999, 1),
('CST_B1_042', 'chest', '철갑 보관함', '육중한 철제 보관함의 다이얼을 운 좋게 맞춰내자, 경쾌한 소리와 함께 귀중품이 드러난다.', 4, 1, 9999, 1),
('CST_B1_043', 'chest', '숨겨진 보물', '책장 뒤편의 비밀 공간을 찾아냈다. 먼지 쌓인 궤짝 안에는 금빛이 찬란하다.', 4, 1, 9999, 1),
('CST_B1_044', 'chest', '물의 보물', '허리까지 차오르는 탁한 물속을 더듬거리다 미끄러운 보물 상자의 손잡이를 쥐었다.', 4, 1, 9999, 1),
('CST_B1_045', 'chest', '고위 마법사의 함', '마력으로 잠겨있던 수정 상자가 사령관의 기운에 반응하며 스르륵 열린다.', 4, 1, 9999, 1),
('CST_B1_046', 'chest', '도적의 장물함', '동굴 구석에 대충 나뭇잎으로 가려놓은 도적들의 장물 상자를 털었다.', 4, 1, 9999, 1),
('CST_B1_047', 'chest', '저주받은 궤짝', '상자를 감고 있던 쇠사슬을 끊어내자 불길한 연기와 함께 진귀한 아티팩트가 보인다.', 4, 1, 9999, 1),
('CST_B1_048', 'chest', '왕실의 하사품', '문장이 새겨진 화려한 궤짝을 발견했다. 세월이 흘렀어도 내용물은 온전하다.', 4, 1, 9999, 1),
('CST_B1_049', 'chest', '뼈로 만든 상자', '동물의 뼈를 깎아 조립한 기괴한 상자를 부수자 그로테스크하지만 값비싼 전리품이 나온다.', 4, 1, 9999, 1),
('CST_B1_050', 'chest', '얼어붙은 금고', '마법적인 냉기로 꽁꽁 얼어붙은 금고를 불로 지져 녹인 후 조심스레 개방한다.', 4, 1, 9999, 1),

-- ==========================================
-- 🩸 함정 (물리적 함정)
-- ==========================================
('TRP_B1_051', 'trap', '솟구치는 창날', '느슨한 타일을 밟는 순간, 바닥에서 튀어나온 강철 창날이 허벅지를 스친다.', 3, 1, 9999, 1),
('TRP_B1_052', 'trap', '떨어지는 칼날', '천장의 밧줄이 끊어지는 소리와 함께 거대한 단두대 칼날이 어깨를 강타한다.', 3, 1, 9999, 1),
('TRP_B1_053', 'trap', '가시 함정벽', '양쪽 벽이 무서운 속도로 좁아지며 가시가 살갗을 찢고 간신히 빠져나온다.', 3, 1, 9999, 1),
('TRP_B1_054', 'trap', '구르는 바위', '인디아나 존스처럼 뒤에서 거대한 원형 바위가 굴러와 필사적으로 뛰다 다리를 접지른다.', 3, 1, 9999, 1),
('TRP_B1_055', 'trap', '독침 소나기', '통로를 지날 때 무수히 많은 작은 구멍에서 마비 독이 발린 바늘이 쏟아진다.', 3, 1, 9999, 1),
('TRP_B1_056', 'trap', '무너지는 바닥', '지지대가 썩어있던 바닥이 붕괴되며 하층으로 떨어지면서 등뼈에 큰 충격을 받는다.', 3, 1, 9999, 1),
('TRP_B1_057', 'trap', '화살 덫', '보이지 않는 실을 건드리자 석궁이 발사되어 복부에 아슬아슬하게 박힌다.', 3, 1, 9999, 1),
('TRP_B1_058', 'trap', '회전 톱니', '벽 사이로 튀어나온 녹슨 회전 톱니바퀴가 방어구를 찢고 피를 흩뿌린다.', 3, 1, 9999, 1),
('TRP_B1_059', 'trap', '마름쇠 구덩이', '어둠 속에 흩뿌려진 날카로운 마름쇠를 밟아 발바닥에 지독한 고통을 느낀다.', 3, 1, 9999, 1),
('TRP_B1_060', 'trap', '올가미 덫', '발목에 올가미가 걸려 공중에 거꾸로 매달리다 추락하며 머리를 부딪힌다.', 3, 1, 9999, 1),

-- ==========================================
-- 🩸 함정 (마법/원소 저주)
-- ==========================================
('TRP_B1_061', 'trap', '폭발성 룬', '문지방에 새겨진 마법 룬을 보지 못하고 밟아 강렬한 열폭발에 휩싸인다.', 3, 1, 9999, 1),
('TRP_B1_062', 'trap', '맹독 구름', '방 중앙에 들어서자 숨을 쉴 수 없는 짙은 보라색 독가스가 뿜어져 나와 각혈을 한다.', 3, 1, 9999, 1),
('TRP_B1_063', 'trap', '영혼 착취', '허공에 떠다니는 기분 나쁜 불빛을 건드리자, 생명력의 일부가 훅 빠져나간다.', 3, 1, 9999, 1),
('TRP_B1_064', 'trap', '동결 마법진', '발을 내딛자마자 주변 온도가 급격히 떨어지며 동상으로 인해 살이 검게 변한다.', 3, 1, 9999, 1),
('TRP_B1_065', 'trap', '산성 점액', '천장에서 기분 나쁘게 떨어지는 점액질이 방어구를 녹이고 피부를 태운다.', 3, 1, 9999, 1),
('TRP_B1_066', 'trap', '부패의 저주', '저주받은 조각상과 눈을 마주치는 순간, 내장이 뒤틀리는 듯한 고통에 시달린다.', 3, 1, 9999, 1),
('TRP_B1_067', 'trap', '전격의 덫', '철창을 잡는 순간 수만 볼트의 번개가 몸을 관통하여 심장이 멎을 뻔한다.', 3, 1, 9999, 1),
('TRP_B1_068', 'trap', '환청의 메아리', '방향 감각을 상실하게 만드는 끔찍한 메아리에 시달리며 벽에 머리를 박고 자해한다.', 3, 1, 9999, 1),
('TRP_B1_069', 'trap', '그림자의 일격', '내 자신의 그림자가 벽에서 분리되더니 짧은 단검으로 옆구리를 찌르고 사라진다.', 3, 1, 9999, 1),
('TRP_B1_070', 'trap', '공간 왜곡', '순간이동 트랩을 잘못 밟아 몸의 절반이 벽돌과 융합될 뻔한 끔찍한 고통을 겪는다.', 3, 1, 9999, 1),

-- ==========================================
-- 💚 회복 (체력/약초/자연)
-- ==========================================
('HEL_B1_071', 'heal', '은은한 빛의 버섯', '어둠 속에서 푸르게 빛나는 버섯을 씹어 먹자 입안에 청량감이 퍼지며 상처가 아문다.', 3, 1, 9999, 1),
('HEL_B1_072', 'heal', '고대의 지혈제', '전투의 흔적이 남은 구석에서 뚜껑을 따지 않은 지혈 연고를 발견해 상처에 바른다.', 3, 1, 9999, 1),
('HEL_B1_073', 'heal', '요정의 눈물', '석순 끝에서 맺혀 떨어지는 맑은 물방울을 받아 마시자 온몸에 생기가 돈다.', 3, 1, 9999, 1),
('HEL_B1_074', 'heal', '기이한 약초', '독기 품은 땅 한가운데 홀로 피어난 순백의 꽃을 빻아 상처에 문질러 회복한다.', 3, 1, 9999, 1),
('HEL_B1_075', 'heal', '따뜻한 빛 한 줄기', '천장의 작은 구멍으로 새어 들어온 한낮의 햇살을 쬐며 굳은 근육을 이완시킨다.', 3, 1, 9999, 1),
('HEL_B1_076', 'heal', '정체불명의 육포', '가방 구석에 남아있던 마른 고기를 질겅거리며 씹어 넘기자 잃었던 기력이 돌아온다.', 3, 1, 9999, 1),
('HEL_B1_077', 'heal', '휴식의 공간', '우연히 발견한 몬스터들이 접근하지 않는 안전한 공터에서 잠시 숨을 고르며 체력을 회복한다.', 3, 1, 9999, 1),
('HEL_B1_078', 'heal', '정화의 마법석', '은은한 열기를 뿜어내는 붉은 마법석을 가슴에 품자 깨진 뼈가 서서히 붙는다.', 3, 1, 9999, 1),
('HEL_B1_079', 'heal', '신성한 수액', '미궁을 뚫고 자라난 세계수의 잔뿌리에서 떨어지는 끈적한 수액을 핥아 생명을 채운다.', 3, 1, 9999, 1),
('HEL_B1_080', 'heal', '여신의 안식', '부서진 여신상 앞에서 잠시 기도를 올리자, 보이지 않는 손길이 이마를 짚어주며 고통을 씻어낸다.', 3, 1, 9999, 1),

-- ==========================================
-- 🔮 회복 (마나/정신력)
-- ==========================================
('MAN_B1_081', 'mana_spring', '순수한 마나 웅덩이', '바닥에 고인 보랏빛 마나의 웅덩이에 손을 담그자 텅 비었던 기해에 마력이 소용돌이친다.', 3, 1, 9999, 1),
('MAN_B1_082', 'mana_spring', '명상의 돌', '오랜 시간 마나를 머금고 있던 거대한 석영 덩어리에 이마를 대자 정신이 아득해질 정도로 마나가 찬다.', 3, 1, 9999, 1),
('MAN_B1_083', 'mana_spring', '별이 쏟아지는 방', '환영 마법으로 밤하늘이 구현된 천장의 방에 들어서자 우주의 기운이 내면의 마나를 일깨운다.', 3, 1, 9999, 1),
('MAN_B1_084', 'mana_spring', '요동치는 대기', '특정 구간을 지나는 순간 대기 중에 흩뿌려진 마나 입자들이 폐 속으로 빨려 들어온다.', 3, 1, 9999, 1),
('MAN_B1_085', 'mana_spring', '영혼의 속삭임', '나를 돕고자 하는 선량한 유령들이 내 주위를 맴돌며 잃어버린 마력을 조금씩 채워준다.', 3, 1, 9999, 1),

-- ==========================================
-- 👻 분위기 묘사 (Flavor Text)
-- ==========================================
('FLV_B1_086', 'flavor', '스산한 침묵', '바람 소리조차 들리지 않는 완벽한 적막이 오히려 고막을 터뜨릴 듯한 압박감을 준다.', 3, 1, 9999, 1),
('FLV_B1_087', 'flavor', '기분 나쁜 그림자', '횃불 빛이 일렁일 때마다 벽에 비친 내 그림자가 마치 내 목을 조르려는 것처럼 보인다.', 3, 1, 9999, 1),
('FLV_B1_088', 'flavor', '먼지 쌓인 거울', '긴 복도 끝에 놓인 낡은 거울에 잠시 내 모습이 비쳤지만, 거울 속의 나는 웃고 있었다.', 3, 1, 9999, 1),
('FLV_B1_089', 'flavor', '정체불명의 체액', '천장에서 뚝, 하고 떨어진 미끌거리는 체액이 어깨에 묻었다. 위를 올려다보기가 두렵다.', 3, 1, 9999, 1),
('FLV_B1_090', 'flavor', '어디선가 들리는 소리', '통로 깊은 곳에서 금속을 톱으로 써는 듯한 기분 나쁜 마찰음이 주기적으로 들려온다.', 3, 1, 9999, 1),
('FLV_B1_091', 'flavor', '버려진 장난감', '미궁에 있을 리 없는 깨끗한 헝겊 인형 하나가 길 한가운데 덩그러니 놓여 있다.', 3, 1, 9999, 1),
('FLV_B1_092', 'flavor', '발자국의 주술', '방금 전까지 내가 밟고 온 발자국들이 일제히 반대 방향을 향해 돌아가 있다.', 3, 1, 9999, 1),
('FLV_B1_093', 'flavor', '식어버린 모닥불', '타다 만 장작에서 한기가 느껴진다. 누군가 방금 전까지 여기 있다가 흔적 없이 사라졌다.', 3, 1, 9999, 1),
('FLV_B1_094', 'flavor', '속삭이는 벽', '벽에 귀를 대자, 수백 명의 사람들이 일제히 기도문을 웅얼거리는 듯한 소리가 진동을 타고 전해진다.', 3, 1, 9999, 1),
('FLV_B1_095', 'flavor', '꺼지지 않는 촛불', '푸른 불꽃을 내는 양초들이 복도를 따라 길게 켜져 있다. 불꽃은 내 쪽을 향해 기울어져 있다.', 3, 1, 9999, 1),

-- ==========================================
-- 📖 지식 및 경험 (EXP)
-- ==========================================
('EXP_B1_096', 'exp', '오래된 전술 일지', '부서진 방패 밑에 깔려 있던 백골의 주머니에서 몬스터의 약점이 적힌 일지를 읽고 깨달음을 얻었다.', 3, 1, 9999, 1),
('EXP_B1_097', 'exp', '고대 마법진 해석', '바닥에 그려진 붉은 진의 공식을 꿰뚫어보며, 마력의 흐름을 효율적으로 다루는 법을 배웠다.', 3, 1, 9999, 1),
('EXP_B1_098', 'exp', '검귀의 궤적', '벽에 남겨진 무수한 검흔을 손가락으로 덧그리며, 전설적인 검사가 휘둘렀을 궤적을 훔쳐 배웠다.', 3, 1, 9999, 1),
('EXP_B1_099', 'exp', '생존자의 기록', '돌벽에 손톱으로 긁어놓은 생존 수칙을 읽으며 던전에서의 위기 대처 능력이 한층 날카로워졌다.', 3, 1, 9999, 1),
('EXP_B1_100', 'exp', '환각 속의 수련', '정체불명의 포자를 들이마시고 환각 속에서 수천 번의 가상 전투를 치르며 정신이 단련되었다.', 3, 1, 9999, 1);

INSERT INTO `tb_explore_events` (`event_code`, `event_type`, `event_title`, `ai_seed`, `weight`, `min_floor`, `max_floor`, `is_enabled`) VALUES
-- ==========================================

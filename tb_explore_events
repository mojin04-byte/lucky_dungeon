-- ==========================================
('ENC_B2_101', 'encounter', '적 조우', '하수구 격자창을 뚫고 거대한 쥐떼가 붉은 눈을 번뜩이며 쏟아져 나온다.', 10, 1, 9999, 1),
('ENC_B2_102', 'encounter', '적 조우', '천장에 매달려 있던 거대한 흡혈 박쥐들이 일제히 날개를 펴고 덮쳐온다.', 10, 1, 9999, 1),
('ENC_B2_103', 'encounter', '적 조우', '어둠 속에서 형체 없는 그림자 사냥개들이 으르렁거리며 포위망을 좁힌다.', 10, 1, 9999, 1),
('ENC_B2_104', 'encounter', '적 조우', '말라죽은 줄 알았던 고목의 뿌리가 기괴하게 비틀리며 저주받은 나무 괴물이 일어난다.', 10, 1, 9999, 1),
('ENC_B2_105', 'encounter', '적 조우', '녹색 점액을 흘리는 거대한 산성 두꺼비가 통로를 가로막고 혀를 날름거린다.', 10, 1, 9999, 1),
('ENC_B2_106', 'encounter', '적 조우', '벽에 장식된 석상인 줄 알았던 가고일 무리가 돌가루를 털어내며 날아오른다.', 10, 1, 9999, 1),
('ENC_B2_107', 'encounter', '적 조우', '여러 구의 시체가 엉겨 붙어 만들어진 살덩어리 골렘이 끔찍한 악취와 함께 다가온다.', 10, 1, 9999, 1),
('ENC_B2_108', 'encounter', '적 조우', '투명한 몸체를 가진 수정 거미들이 날카로운 다리로 바닥을 긁으며 쇄도한다.', 10, 1, 9999, 1),
('ENC_B2_109', 'encounter', '적 조우', '바닥의 갈라진 틈에서 맹독을 품은 거대 뱀이 쉿쉿 소리를 내며 솟아오른다.', 10, 1, 9999, 1),
('ENC_B2_110', 'encounter', '적 조우', '거대한 짐승의 뼈가 마력에 의해 조립되더니 언데드 웜이 되어 포효한다.', 10, 1, 9999, 1),

-- ==========================================
-- ⚔️ 적 조우 (언데드 및 마법형)
-- ==========================================
('ENC_B2_111', 'encounter', '적 조우', '차디찬 한기와 함께 허공에서 반투명한 레이스가 날카로운 비명을 지른다.', 10, 1, 9999, 1),
('ENC_B2_112', 'encounter', '적 조우', '아름다운 여인의 울음소리에 이끌려 다가간 곳엔 끔찍한 밴시가 기다리고 있었다.', 10, 1, 9999, 1),
('ENC_B2_113', 'encounter', '적 조우', '푸른 인광을 뿜어내는 해골 마법사들이 진형을 갖추고 마력탄을 준비한다.', 10, 1, 9999, 1),
('ENC_B2_114', 'encounter', '적 조우', '녹슨 갑옷을 입은 좀비 기사들이 기분 나쁜 소리를 내며 대검을 치켜든다.', 10, 1, 9999, 1),
('ENC_B2_115', 'encounter', '적 조우', '머리 없는 기사가 유령마를 타고 복도 끝에서부터 맹렬히 돌격해 온다.', 10, 1, 9999, 1),
('ENC_B2_116', 'encounter', '적 조우', '벽 속으로 스며들었던 환영 암살자가 등 뒤에서 소리 없이 실체화된다.', 10, 1, 9999, 1),
('ENC_B2_117', 'encounter', '적 조우', '시체들을 부리던 강령술사가 불쾌한 미소를 지으며 저주를 읊조리기 시작한다.', 10, 1, 9999, 1),
('ENC_B2_118', 'encounter', '적 조우', '버려진 아이의 인형이 기괴하게 목을 꺾으며 독이 묻은 바늘을 들고 덤벼든다.', 10, 1, 9999, 1),
('ENC_B2_119', 'encounter', '적 조우', '바닥에 고여 있던 피들이 뭉쳐지며 거대한 선혈의 정령으로 피어오른다.', 10, 1, 9999, 1),
('ENC_B2_120', 'encounter', '적 조우', '금화 무더기인 줄 알고 다가간 순간, 거대한 미믹이 소름 돋는 이빨을 드러낸다.', 10, 1, 9999, 1),


('ENC_B3_201', 'encounter', '적 조우', '피 웅덩이에서 솟아오른 핏빛 기사가 점액이 뚝뚝 떨어지는 대검을 휘두른다.', 10, 1, 9999, 1),
('ENC_B3_202', 'encounter', '적 조우', '허공에 떠다니던 안구들이 하나로 뭉쳐 거대하고 기괴한 마안(魔眼) 괴물이 된다.', 10, 1, 9999, 1),
('ENC_B3_203', 'encounter', '적 조우', '벽에 박힌 수백 개의 손목들이 일제히 무기를 집어 들고 튀어나와 덮쳐온다.', 10, 1, 9999, 1),
('ENC_B3_204', 'encounter', '적 조우', '죽어버린 고대의 드래곤 뼈가 불길한 흑마법으로 다시 조립되며 거대한 포효를 내지른다.', 10, 1, 9999, 1),
('ENC_B3_205', 'encounter', '적 조우', '환각 포자를 뿜어내는 기괴한 돌연변이 식물이 가시 돋친 촉수로 사령관을 옭아매려 한다.', 10, 1, 9999, 1),
('ENC_B3_206', 'encounter', '적 조우', '썩은 고기를 탐하는 거대 구더기 떼가 바닥을 새카맣게 뒤덮으며 파도처럼 밀려온다.', 10, 1, 9999, 1),
('ENC_B3_207', 'encounter', '적 조우', '천장의 종유석인 줄 알았던 것들이 일제히 눈을 번뜩이며 박쥐 괴물로 변해 날아든다.', 10, 1, 9999, 1),
('ENC_B3_208', 'encounter', '적 조우', '시체 구덩이에서 살아남은 악취 나는 좀비 쥐 떼가 날카로운 앞니를 세우고 달려든다.', 10, 1, 9999, 1),
('ENC_B3_209', 'encounter', '적 조우', '바닥의 진흙이 사람의 형태를 갖추더니 흉측한 진흙 골렘이 되어 무거운 발걸음을 옮긴다.', 10, 1, 9999, 1),
('ENC_B3_210', 'encounter', '적 조우', '온몸이 날카로운 수정으로 덮인 동굴 전갈이 쇳소리를 내며 독침을 세운다.', 10, 1, 9999, 1),

-- ==========================================
-- ⚔️ 적 조우 (언데드 및 타락한 자들)
-- ==========================================
('ENC_B3_211', 'encounter', '적 조우', '금빛 갑옷을 입은 타락한 성기사가 성스러운 빛 대신 검은 불꽃을 뿜어내며 돌진한다.', 10, 1, 9999, 1),
('ENC_B3_212', 'encounter', '적 조우', '녹슨 철퇴를 끄는 사형집행인의 망령이 억울한 영혼들의 비명 소리를 동반하며 나타난다.', 10, 1, 9999, 1),
('ENC_B3_213', 'encounter', '적 조우', '어둠의 마법에 중독된 학자가 제정신을 잃고 주변의 마력을 무차별적으로 폭발시킨다.', 10, 1, 9999, 1),
('ENC_B3_214', 'encounter', '적 조우', '수백 년 전 죽은 황제의 미라가 황금 검을 뽑아 들고 침입자를 향해 진격 명령을 내린다.', 10, 1, 9999, 1),
('ENC_B3_215', 'encounter', '적 조우', '몸이 반으로 찢겨나간 강시가 기괴한 속도로 바닥을 기어 오며 저주를 읊조린다.', 10, 1, 9999, 1),
('ENC_B3_216', 'encounter', '적 조우', '과거 이곳을 정벌하려다 전멸한 고대의 보병대가 해골이 되어서도 진형을 잃지 않고 다가온다.', 10, 1, 9999, 1),
('ENC_B3_217', 'encounter', '적 조우', '형체 없는 원혼들이 사령관의 눈과 귀를 가리며 뼛속까지 시린 냉기로 영혼을 갉아먹으려 한다.', 10, 1, 9999, 1),
('ENC_B3_218', 'encounter', '적 조우', '자신을 여신이라 믿는 미쳐버린 마녀가 환영의 날개를 달고 치명적인 광선 마법을 쏜다.', 10, 1, 9999, 1),
('ENC_B3_219', 'encounter', '적 조우', '살점을 기워 만든 괴물 프랑켄슈타인이 쇠사슬을 끊고 미친 듯이 울부짖으며 주먹을 내리친다.', 10, 1, 9999, 1),
('ENC_B3_220', 'encounter', '적 조우', '저주받은 음유시인이 켜는 기괴한 류트 소리에 맞춰 언데드들이 춤을 추듯 공격해온다.', 10, 1, 9999, 1),

-- ==========================================
-- ⚔️ 적 조우 (기습 및 함정 연계)
-- ==========================================
('ENC_B3_221', 'encounter', '적 조우', '천장에 거꾸로 매달려 있던 암살자가 조용히 독 단검을 떨어뜨리며 뱀처럼 덮쳐온다.', 10, 1, 9999, 1),
('ENC_B3_222', 'encounter', '적 조우', '방을 가득 채운 거울들이 일제히 깨지며, 거울 속의 뒤틀린 환영들이 무기를 들고 튀어나온다.', 10, 1, 9999, 1),
('ENC_B3_223', 'encounter', '적 조우', '보물 상자처럼 꾸며진 정교한 함정 문이 열리며 기계 태엽으로 움직이는 거대 거미가 튀어나온다.', 10, 1, 9999, 1),
('ENC_B3_224', 'encounter', '적 조우', '죽은 척 쓰러져 있던 고블린 병사들이 사령관이 지나가는 순간 일제히 발목을 찌르며 일어난다.', 10, 1, 9999, 1),
('ENC_B3_225', 'encounter', '적 조우', '가짜 회복의 옹달샘에서 휴식을 취하려는 순간, 물이 핏빛으로 변하며 늪지 괴물이 솟아오른다.', 10, 1, 9999, 1),
('ENC_B3_226', 'encounter', '적 조우', '벽 뒤에 교묘히 파놓은 살인 구덩이에서 창을 든 이교도들이 함성을 지르며 기습한다.', 10, 1, 9999, 1),
('ENC_B3_227', 'encounter', '적 조우', '어둠 속에서 반짝이는 보석인 줄 알고 다가갔으나, 그것은 거대 독사의 눈동자였다.', 10, 1, 9999, 1),
('ENC_B3_228', 'encounter', '적 조우', '복도 양끝에서 무거운 쇠창살이 내려와 퇴로가 막히고, 숨어있던 무장 강도들이 모습을 드러낸다.', 10, 1, 9999, 1),
('ENC_B3_229', 'encounter', '적 조우', '공중에 떠다니는 기이한 안개가 사령관의 그림자에 스며들더니, 도플갱어로 변해 공격한다.', 10, 1, 9999, 1),
('ENC_B3_230', 'encounter', '적 조우', '안전한 방인 줄 알고 문을 닫는 순간, 문과 벽이 살아있는 미믹 둥지였음을 깨닫는다.', 10, 1, 9999, 1),

-- ==========================================
-- 💰 골드 획득 (디테일한 파밍 묘사)
-- ==========================================
('GLD_B3_231', 'gold', '저주받은 루비', '제단에 바쳐진 해골의 텅 빈 눈구멍에 박혀 있던 가치 있는 루비를 단검으로 파냈다.', 4, 1, 9999, 1),
('GLD_B3_232', 'gold', '파묻힌 주머니', '이끼 낀 돌무더기를 들추자 누군가 급히 파묻어둔 묵직한 동전 주머니가 발견되었다.', 4, 1, 9999, 1),
('GLD_B3_233', 'gold', '용병의 금목걸이', '함정에 걸려 죽은 불쌍한 용병의 목에 걸려 있던 두꺼운 순금 목걸이를 거둬들인다.', 4, 1, 9999, 1),
('GLD_B3_234', 'gold', '빛을 잃은 왕관', '바닥에 나뒹구는 녹슨 철제 투구 사이에서, 진짜 금으로 세공된 왕관의 파편을 찾아냈다.', 4, 1, 9999, 1),
('GLD_B3_235', 'gold', '항아리 속 은화', '구석에 버려진 금이 간 도자기 항아리를 깨뜨리자 그 안에 숨겨져 있던 은화들이 쏟아진다.', 4, 1, 9999, 1),
('GLD_B3_236', 'gold', '거미줄 틈새의 보석', '두꺼운 거미줄을 횃불로 지지자, 거미줄에 걸려 있던 반짝이는 보석 몇 알이 바닥으로 떨어진다.', 4, 1, 9999, 1),
('GLD_B3_237', 'gold', '찢어진 융단', '화려하지만 너덜거리는 붉은 융단을 들춰내자 바닥 타일 틈새에 박힌 금괴를 발견한다.', 4, 1, 9999, 1),
('GLD_B3_238', 'gold', '마법사의 지팡이', '부러진 낡은 마법 지팡이의 끝에 달려 있던 영롱한 마력석을 떼어내어 가방에 넣는다.', 4, 1, 9999, 1),
('GLD_B3_239', 'gold', '녹아내린 촛대', '불타버린 방 한구석에서 열기에 반쯤 녹아내린 거대한 은제 촛대를 주워 담는다.', 4, 1, 9999, 1),
('GLD_B3_240', 'gold', '기괴한 저금통', '악마의 입 모양을 한 기괴한 조각상 입속으로 손을 집어넣어, 바닥에 깔린 주화들을 꺼낸다.', 4, 1, 9999, 1),

-- ==========================================
-- 📦 상자 발견 (독특한 궤짝들)
-- ==========================================
('CST_B3_241', 'chest', '흑요석 상자', '용암이 흐르는 틈새 아슬아슬한 바위 위에 놓인 흑요석 상자를 갈고리로 간신히 끌어와 열었다.', 4, 1, 9999, 1),
('CST_B3_242', 'chest', '장미 넝쿨 상자', '아름답지만 날카로운 장미 넝쿨로 덮인 백은 상자의 가시를 검으로 베어내고 전리품을 챙긴다.', 4, 1, 9999, 1),
('CST_B3_243', 'chest', '해골 자물쇠', '말을 거는 기괴한 해골 자물쇠의 수수께끼를 풀어내자 상자가 덜컥 열리며 금빛이 쏟아진다.', 4, 1, 9999, 1),
('CST_B3_244', 'chest', '숨겨진 벽장', '벽의 미세한 균열을 눌러 비밀 벽장을 열자, 온전하게 보존된 고대의 보물함이 나타난다.', 4, 1, 9999, 1),
('CST_B3_245', 'chest', '가라앉은 궤짝', '피비린내 나는 붉은 연못 바닥에서 쇠사슬에 묶인 무거운 궤짝을 건져 올려 봉인을 해제한다.', 4, 1, 9999, 1),
('CST_B3_246', 'chest', '떠다니는 상자', '마법의 힘으로 방 한가운데 공중에 떠 있는 상자를 잡아채어 마력으로 잠금을 해제한다.', 4, 1, 9999, 1),
('CST_B3_247', 'chest', '음각의 큐브', '표면에 빼곡히 주문이 음각된 신비로운 큐브 상자의 배열을 맞추자 부품이 풀리며 보석이 나온다.', 4, 1, 9999, 1),
('CST_B3_248', 'chest', '오르골 상자', '상자를 여는 순간 태엽이 돌아가며 기괴한 오르골 소리가 나지만, 안에는 값진 유물이 들어있다.', 4, 1, 9999, 1),
('CST_B3_249', 'chest', '얼음 수정함', '투명한 얼음 수정으로 만들어진 상자를 망치로 조심스레 깨뜨려 내부에 보관된 룬을 확보한다.', 4, 1, 9999, 1),
('CST_B3_250', 'chest', '거미여왕의 보물', '거미줄로 빈틈없이 봉인된 거대 고치를 불로 태워내자 그 안에서 희생자들의 귀중품 상자가 나온다.', 4, 1, 9999, 1),

-- ==========================================
-- 🩸 함정 (기계/물리/화학 함정)
-- ==========================================
('TRP_B3_251', 'trap', '산성 분출', '압력판을 밟는 순간, 양쪽 벽의 미세한 틈에서 강력한 산성액이 뿜어져 나와 피부를 태운다.', 3, 1, 9999, 1),
('TRP_B3_252', 'trap', '함정 문', '발밑의 타일이 갑자기 180도로 회전하며 날카로운 칼날이 깔린 구덩이로 떨어질 뻔한다.', 3, 1, 9999, 1),
('TRP_B3_253', 'trap', '그물 덫', '어둠 속에 쳐진 투명한 강철 그물에 걸려 공중으로 솟구치며 온몸이 찢어지는 고통을 겪는다.', 3, 1, 9999, 1),
('TRP_B3_254', 'trap', '화살 폭풍', '문을 여는 각도에 연동된 기계 석궁들이 일제히 발사되어 어깨와 허벅지에 화살이 박힌다.', 3, 1, 9999, 1),
('TRP_B3_255', 'trap', '철퇴 함정', '코너를 도는 순간 천장에서 육중한 가시 철퇴가 그네처럼 날아와 갈비뼈를 산산조각 낸다.', 3, 1, 9999, 1),
('TRP_B3_256', 'trap', '독기 품은 가시', '무심코 짚은 벽면의 덩굴에 맹독을 품은 날카로운 가시가 숨어있어 손바닥이 까맣게 타들어간다.', 3, 1, 9999, 1),
('TRP_B3_257', 'trap', '모래지옥', '안전해 보이던 모래 바닥이 늪처럼 푹 꺼지며 허리까지 빨려 들어가 간신히 기어나온다.', 3, 1, 9999, 1),
('TRP_B3_258', 'trap', '기요틴', '아치형 문을 통과할 때 센서가 작동하며 날카로운 단두대 칼날이 떨어져 목덜미를 스친다.', 3, 1, 9999, 1),
('TRP_B3_259', 'trap', '천장 압박', '방의 출입문이 닫히며 천장 전체가 무서운 속도로 내려와 온몸의 뼈를 으스러뜨릴 뻔한다.', 3, 1, 9999, 1),
('TRP_B3_260', 'trap', '석화 가스', '열린 관에서 뿜어져 나온 회색 가스를 마시자, 관절이 돌처럼 굳어지며 심각한 근육 파열이 일어난다.', 3, 1, 9999, 1),


('ENC_B4_301', 'encounter', '적 조우', '거대한 뱀 껍질을 뚫고 나온 흉측한 쌍두사가 쉿쉿거리며 독액을 뿜어낸다.', 10, 1, 9999, 1),
('ENC_B4_302', 'encounter', '적 조우', '부패한 웅덩이에서 거품이 일더니, 뼈와 진흙으로 뭉쳐진 늪지 거수가 솟아오른다.', 10, 1, 9999, 1),
('ENC_B4_303', 'encounter', '적 조우', '벽면을 갉아먹고 있던 거대 산성 딱정벌레 떼가 먹잇감을 발견하고 날개를 편다.', 10, 1, 9999, 1),
('ENC_B4_304', 'encounter', '적 조우', '어둠 속에서 날카로운 가시를 쏘아대는 지하 가시멧돼지가 돌진해온다.', 10, 1, 9999, 1),
('ENC_B4_305', 'encounter', '적 조우', '피 냄새를 맡고 천장에서 툭, 툭 떨어지는 수십 마리의 흡혈 거머리 떼와 조우한다.', 10, 1, 9999, 1),
('ENC_B4_306', 'encounter', '적 조우', '시력은 퇴화했지만 청각이 극도로 예민해진 동굴 트롤이 숨소리를 듣고 몽둥이를 휘두른다.', 10, 1, 9999, 1),
('ENC_B4_307', 'encounter', '적 조우', '천장에 매달려 인분과 산성 침을 뱉어내는 거대한 독나방이 날개를 펄럭인다.', 10, 1, 9999, 1),
('ENC_B4_308', 'encounter', '적 조우', '죽은 동료의 뼈를 뒤집어쓴 기괴한 하이에나 마수들이 웃음소리 같은 울음을 내며 포위한다.', 10, 1, 9999, 1),
('ENC_B4_309', 'encounter', '적 조우', '열기가 훅 끼쳐오는 통로 끝에서, 용암을 몸에 두른 불도마뱀이 입을 벌린다.', 10, 1, 9999, 1),
('ENC_B4_310', 'encounter', '적 조우', '오염된 마나로 돌연변이를 일으켜 집채만 해진 흉포한 쥐의 왕이 수하들을 이끌고 덮친다.', 10, 1, 9999, 1),

-- ==========================================
-- ⚔️ 적 조우 (언데드 및 타락한 마법)
-- ==========================================
('ENC_B4_311', 'encounter', '적 조우', '녹슨 사슬에 묶인 채 억울하게 죽어간 망령들이 사슬을 휘두르며 원한을 토해낸다.', 10, 1, 9999, 1),
('ENC_B4_312', 'encounter', '적 조우', '죽은 자의 뼈를 모아 기괴한 골렘을 연성하고 있는 네크로맨서를 급습했다.', 10, 1, 9999, 1),
('ENC_B4_313', 'encounter', '적 조우', '머리가 없는 기사가 자신의 잘린 목 대신 부서진 방패를 들고 무자비하게 덤벼든다.', 10, 1, 9999, 1),
('ENC_B4_314', 'encounter', '적 조우', '어둠 속에서 형체를 바꾸며 물리 공격을 회피하는 기만적인 그림자 정령과 마주쳤다.', 10, 1, 9999, 1),
('ENC_B4_315', 'encounter', '적 조우', '눈동자 없이 찢어진 입만 있는 귀신이 기분 나쁜 소리로 웃으며 허공을 유영해 다가온다.', 10, 1, 9999, 1),
('ENC_B4_316', 'encounter', '적 조우', '떠도는 영혼들이 하나로 뭉쳐 미궁의 통로를 가득 채우는 거대한 원혼의 소용돌이가 된다.', 10, 1, 9999, 1),
('ENC_B4_317', 'encounter', '적 조우', '오래된 무덤의 수호진을 밟자, 뼈만 남은 스켈레톤 근위대원들이 창과 방패를 들고 일어선다.', 10, 1, 9999, 1),
('ENC_B4_318', 'encounter', '적 조우', '흑마법의 여파로 살점이 녹아내린 타락한 수도사가 광기 어린 눈빛으로 산성 마법을 시전한다.', 10, 1, 9999, 1),
('ENC_B4_319', 'encounter', '적 조우', '부서진 마법 거울 조각에서 기어나온 사령관 자신의 복제된 환영과 목숨을 건 혈투를 벌인다.', 10, 1, 9999, 1),
('ENC_B4_320', 'encounter', '적 조우', '고대 제단 위에서 억울하게 희생된 처녀의 원혼이 피눈물을 흘리며 저주의 비명을 지른다.', 10, 1, 9999, 1),

-- ==========================================
-- ⚔️ 적 조우 (기습 및 함정 연계)
-- ==========================================
('ENC_B4_321', 'encounter', '적 조우', '어둠 속에 완벽하게 숨어 독 화살을 겨누고 있던 고블린 저격수 무리의 기습을 받는다.', 10, 1, 9999, 1),
('ENC_B4_322', 'encounter', '적 조우', '약탈의 기회를 노리며 미행하던 비열한 도적 떼가 사령관이 지치기를 기다렸다 단검을 빼든다.', 10, 1, 9999, 1),
('ENC_B4_323', 'encounter', '적 조우', '동료인 척 함정에 빠진 연기를 하던 미궁의 식인종 부족원이 뒤통수를 향해 둔기를 휘두른다.', 10, 1, 9999, 1),
('ENC_B4_324', 'encounter', '적 조우', '마력의 폭주로 광기에 사로잡힌 떠돌이 검사가 피아를 구분하지 못하고 미친 듯이 칼을 휘두른다.', 10, 1, 9999, 1),
('ENC_B4_325', 'encounter', '적 조우', '미궁의 보물에 눈이 멀어 자신의 파티를 몰살시킨 광기의 암살자가 다음 타겟으로 사령관을 노린다.', 10, 1, 9999, 1),
('ENC_B4_326', 'encounter', '적 조우', '스스로 이단 심문관이라 칭하는 미치광이가 정화의 불꽃을 던지며 좁은 통로를 화염으로 막아선다.', 10, 1, 9999, 1),

('GLD_B4_336', 'gold', '순금 화살촉', '벽에 깊숙이 박힌 오래된 화살을 뽑아내어 보니, 그 화살촉이 무려 순금으로 만들어져 있었다.', 4, 1, 9999, 1),
('GLD_B4_337', 'gold', '마도서의 책갈피', '바닥을 뒹구는 낡고 해진 마도서 페이지 사이에 끼워져 있던 값비싼 금박 책갈피를 빼낸다.', 4, 1, 9999, 1),

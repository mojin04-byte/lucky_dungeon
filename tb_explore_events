-- 🩸 함정 (마법/저주/심리)
-- ==========================================
('TRP_B3_261', 'trap', '피의 낙인', '바닥에 새겨진 마법진을 밟자, 이마에 붉은 낙인이 찍히며 끓어오르는 듯한 고통이 전신을 덮친다.', 3, 1, 9999, 1),
('TRP_B3_262', 'trap', '절망의 환영', '과거에 죽어간 동료들의 환영이 나타나 내 목을 조르는 끔찍한 환각에 빠져 발작을 일으킨다.', 3, 1, 9999, 1),
('TRP_B3_263', 'trap', '그림자 속박', '바닥에 비친 내 그림자가 갑자기 실체화되어 발목을 강하게 부러뜨릴 듯이 쥐고 꺾어버린다.', 3, 1, 9999, 1),
('TRP_B3_264', 'trap', '빙결 룬', '잘못 건드린 룬석에서 절대영도의 냉기가 폭발하며 양손이 파랗게 동상을 입고 감각을 잃는다.', 3, 1, 9999, 1),
('TRP_B3_265', 'trap', '혼돈의 구슬', '호기심에 만진 탁한 구슬에서 번갯불이 튀어 오르며 뇌세포가 타들어가는 극심한 충격을 받는다.', 3, 1, 9999, 1),
('TRP_B3_266', 'trap', '부패한 영혼', '벽에 봉인되어 있던 악령이 풀려나며 내 가슴을 관통해 지나가고, 심장이 멎는 듯한 고통에 쓰러진다.', 3, 1, 9999, 1),
('TRP_B3_267', 'trap', '불길의 덫', '통로 양옆의 횃불이 갑자기 미친 듯이 타오르며 길 전체를 화염으로 뒤덮어 전신 화상을 입는다.', 3, 1, 9999, 1),
('TRP_B3_268', 'trap', '마력 폭주', '함정에 걸리는 순간 몸속의 마력이 통제를 잃고 역류하여 혈관이 찢어지는 듯한 고통을 겪는다.', 3, 1, 9999, 1),
('TRP_B3_269', 'trap', '공포의 메아리', '방 전체에 울려 퍼지는 섬뜩한 비명 소리가 고막을 찢고 뇌를 짓눌러 코피를 쏟게 만든다.', 3, 1, 9999, 1),
('TRP_B3_270', 'trap', '저주받은 인형', '우연히 주운 헝겊 인형의 목이 꺾이는 순간, 내 목의 뼈마디가 비명을 지르며 강제로 비틀린다.', 3, 1, 9999, 1),

-- ==========================================
-- 💚 회복 (약초, 신성한 물, 치유 마법)
-- ==========================================
('HEL_B3_271', 'heal', '기적의 백합', '미궁 깊은 곳에서 오염을 이겨내고 피어난 기적의 백합 꽃잎을 씹어 먹자 호흡이 편안해진다.', 3, 1, 9999, 1),
('HEL_B3_272', 'heal', '정화된 석회수', '벽의 틈새로 흘러내리는 맑은 석회수를 손바닥으로 받아 마시며 목마름과 상처의 열기를 식힌다.', 3, 1, 9999, 1),
('HEL_B3_273', 'heal', '성직자의 유품', '이름 모를 성직자가 남긴 은제 성배에 고인 성수를 마시자 전신의 저주와 독기가 씻겨 내려간다.', 3, 1, 9999, 1),
('HEL_B3_274', 'heal', '황금 사과', '마법으로 자라난 듯한 작은 나무에서 열린 황금빛 사과를 한 입 베어 물자 상처가 욱신거리며 회복된다.', 3, 1, 9999, 1),
('HEL_B3_275', 'heal', '치유의 진', '누군가 그려놓고 간 희미한 녹색 마법진 위에 앉아 숨을 고르자 찢어진 피부 조직이 재생된다.', 3, 1, 9999, 1),
('HEL_B3_276', 'heal', '마력석 연고', '가방에 있던 부서진 치유의 마력석 가루를 긁어모아 상처에 문지르자 뜨거운 기운과 함께 지혈된다.', 3, 1, 9999, 1),
('HEL_B3_277', 'heal', '정령의 입맞춤', '어둠 속에서 나타난 작은 빛의 정령이 상처 부위에 내려앉아 따스한 빛을 내뿜고 사라진다.', 3, 1, 9999, 1),
('HEL_B3_278', 'heal', '따뜻한 모닥불 터', '아직 온기가 남아있는 누군가의 모닥불 터 곁에서 굳은 근육을 녹이고 깊은 휴식을 취한다.', 3, 1, 9999, 1),
('HEL_B3_279', 'heal', '결정화된 수액', '호박(Amber)처럼 굳어있는 고대 나무의 수액 덩어리를 녹여 마시자 잃었던 생명력이 용솟음친다.', 3, 1, 9999, 1),
('HEL_B3_280', 'heal', '여명의 빛', '천장의 무너진 틈을 통해 기적처럼 쏟아지는 아침의 여명 빛줄기를 받으며 피로를 완전히 날려버린다.', 3, 1, 9999, 1),

-- ==========================================
-- 🔮 회복 (마나/정신력 보충)
-- ==========================================
('MAN_B3_281', 'mana_spring', '마력탑의 파편', '파괴된 고대 마력탑의 파편에서 흘러나오는 푸른 잔류 마나를 깊이 들이마셔 기해를 채운다.', 3, 1, 9999, 1),
('MAN_B3_282', 'mana_spring', '에테르 구름', '통로 한가운데 머물러 있는 신비한 에테르 안개 구름 속을 걸어가자 흐트러진 정신력이 맑아진다.', 3, 1, 9999, 1),
('MAN_B3_283', 'mana_spring', '수정 동굴', '사방이 뾰족한 보랏빛 수정으로 뒤덮인 방에 들어서자 공명하는 마력이 메마른 영혼을 적신다.', 3, 1, 9999, 1),
('MAN_B3_284', 'mana_spring', '마법사의 유산', '백골이 된 마법사가 품고 있던 온전한 마나 물약을 조심스럽게 들이켜 텅 빈 마력을 회복한다.', 3, 1, 9999, 1),
('MAN_B3_285', 'mana_spring', '성스러운 종소리', '어디선가 환청처럼 들려오는 은은한 성당의 종소리가 마음의 평안을 가져다주며 기력을 북돋운다.', 3, 1, 9999, 1),

-- ==========================================
-- 👻 분위기 묘사 (Flavor - 심리적 공포와 긴장감)
-- ==========================================
('FLV_B3_286', 'flavor', '부르는 소리', '어디선가 내 이름을 부르는 익숙한 목소리가 들리지만, 돌아보면 짙은 어둠과 적막뿐이다.', 3, 1, 9999, 1),
('FLV_B3_287', 'flavor', '착시 현상', '벽면을 타고 흐르는 평범한 물방울들이 횃불 빛에 반사되어 마치 붉은 피가 흘러내리는 것처럼 보인다.', 3, 1, 9999, 1),
('FLV_B3_288', 'flavor', '누군가의 숨결', '혼자뿐인 좁은 통로에서 누군가 귓가에 대고 차가운 입김을 불어넣은 듯 솜털이 바짝 선다.', 3, 1, 9999, 1),
('FLV_B3_289', 'flavor', '기묘한 웃음', '멀리서 어린아이들의 까르르 웃는 소리가 들려오더니 이내 기분 나쁜 노인의 기침 소리로 변한다.', 3, 1, 9999, 1),
('FLV_B3_290', 'flavor', '바뀐 방향', '분명 오른쪽으로 꺾었다고 생각했는데, 나침반과 바닥의 흔적은 내가 계속 제자리를 돌고 있음을 가리킨다.', 3, 1, 9999, 1),
('FLV_B3_291', 'flavor', '시선의 압박', '어둠 속에 웅크리고 있는 수십 개의 기괴한 석상들의 시선이 내가 움직일 때마다 따라오는 것만 같다.', 3, 1, 9999, 1),
('FLV_B3_292', 'flavor', '녹슨 사슬 소리', '바닥을 끌며 다가오는 묵직하고 녹슨 쇠사슬 소리가 들려 황급히 무기를 쥐었으나 아무도 나타나지 않는다.', 3, 1, 9999, 1),
('FLV_B3_293', 'flavor', '피 묻은 손자국', '방금 전까지 없었던, 성인 남성의 손보다 두 배는 큰 피 묻은 손자국이 내 어깨 높이의 벽에 찍혀 있다.', 3, 1, 9999, 1),
('FLV_B3_294', 'flavor', '질식할 듯한 공기', '갑자기 공기가 물처럼 무겁고 끈적하게 변하며 폐에 산소가 공급되지 않는 듯한 숨 막힘을 느낀다.', 3, 1, 9999, 1),
('FLV_B3_295', 'flavor', '사라진 그림자', '횃불을 높이 들었음에도 불구하고 내 발밑에 있어야 할 내 그림자가 감쪽같이 사라져 보이지 않는다.', 3, 1, 9999, 1),

-- ==========================================
-- 📖 지식 및 경험 (EXP - 깨달음과 성장의 순간)
-- ==========================================
('EXP_B3_296', 'exp', '마법사의 해석', '바스라진 석판에 새겨진 잊혀진 마법사들의 전투 공식을 해독하여 마나 운용에 대한 새로운 깨달음을 얻었다.', 3, 1, 9999, 1),
('EXP_B3_297', 'exp', '검술의 이해', '전사한 고대 기사의 대검에 새겨진 룬 문자를 훑어보며, 무기를 다루는 무게 중심과 궤적의 깊이를 이해하게 되었다.', 3, 1, 9999, 1),
('EXP_B3_298', 'exp', '약점의 통찰', '해부된 채 버려진 기괴한 마수의 사체를 꼼꼼히 관찰하며, 두꺼운 가죽 아래 숨겨진 치명적인 급소를 파악했다.', 3, 1, 9999, 1),
('EXP_B3_299', 'exp', '생존의 감각', '교묘하게 설치되어 작동하지 않은 불발된 함정의 기계적 구조를 뜯어보며, 함정을 회피하는 육감적인 감각이 예리해졌다.', 3, 1, 9999, 1),
('EXP_B3_300', 'exp', '사령관의 자질', '피로 얼룩진 과거 지휘관의 일기장을 읽으며, 극도의 공포 속에서도 부대를 지휘할 수 있는 강인한 정신력을 체득했다.', 3, 1, 9999, 1);

INSERT INTO `tb_explore_events` (`event_code`, `event_type`, `event_title`, `ai_seed`, `weight`, `min_floor`, `max_floor`, `is_enabled`) VALUES
-- ==========================================
-- ⚔️ 적 조우 (야수 및 기괴한 생명체)

('EXP_B2_196', 'exp', '핏빛 지도', '바닥에 급하게 휘갈겨진 핏빛 지도를 해독하여 미궁의 지형지물 활용법을 터득했다.', 3, 1, 9999, 1),
('EXP_B2_197', 'exp', '바람의 명상', '바람이 통하는 작은 구멍 앞에서 가부좌를 틀고 명상하며 내면의 잠재력을 일깨운다.', 3, 1, 9999, 1),
('EXP_B2_198', 'exp', '고대의 벽화', '고대 언어로 새겨진 벽화의 전투 묘사를 해석하여 무기를 휘두르는 최적의 궤적을 배웠다.', 3, 1, 9999, 1),
('EXP_B2_199', 'exp', '괴수의 발자국', '거대한 괴수의 발자국과 사냥 방식이 남긴 흔적을 역추적하며 몬스터 생태의 약점을 파악했다.', 3, 1, 9999, 1),
('EXP_B2_200', 'exp', '기사의 수양록', '이름 모를 기사의 해골 품에서 발견한 낡은 수양록을 읽고 기사도의 굳건한 정신력을 체득했다.', 3, 1, 9999, 1);

INSERT INTO `tb_explore_events` (`event_code`, `event_type`, `event_title`, `ai_seed`, `weight`, `min_floor`, `max_floor`, `is_enabled`) VALUES
-- ==========================================
